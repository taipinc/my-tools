---
import { categories } from "../data/tools";

const { activeSlug } = Astro.props as { activeSlug?: string };
const base = import.meta.env.BASE_URL;
---

<aside
    class="sticky top-0 h-screen w-72 shrink-0 border-r border-[var(--color-rule)] bg-[var(--color-paper-2)]/40 overflow-y-auto"
>
    <div class="px-5 pt-6 pb-4 border-b border-[var(--color-rule)]">
        <a href={base} class="block group">
            <div
                class="text-xl font-semibold tracking-tight text-[var(--color-ink)]"
            >
                Shabtai's Teaching Tools
            </div>
            <div
                class="text-[12px] tracking-[0.18em] text-[var(--color-ink-soft)] mt-1"
            >
                a small classroom toolkit
            </div>
        </a>
    </div>

    <nav class="px-3 py-4 space-y-6 text-[15px]">
        <a
            href={base}
            class={`block px-2 py-1.5 rounded ${!activeSlug ? "bg-[var(--color-accent-soft)] text-[var(--color-ink)]" : "hover:bg-[var(--color-paper-2)] text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]"}`}
        >
            ▸ Home
        </a>

        {
            categories.map((category) => (
                <div>
                    <div class="px-2 mb-2 text-[12px] font-extrabold text-[var(--color-ink)]">
                        {category.name}
                    </div>
                    {category.tools.length === 0 ? (
                        <div class="px-2 py-1 text-[13px] italic text-[var(--color-ink-soft)] opacity-70">
                            — nothing here yet —
                        </div>
                    ) : (
                        <ul class="space-y-0.5">
                            {category.tools.map((tool) => {
                                const active = tool.slug === activeSlug;
                                return (
                                    <li>
                                        <a
                                            href={`${base}tools/${tool.slug}`}
                                            class={`flex items-center justify-between px-2 py-1.5 rounded ${active ? "bg-[var(--color-accent-soft)] text-[var(--color-ink)]" : "hover:bg-[var(--color-paper-2)] text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]"}`}
                                        >
                                            <span>{tool.name}</span>
                                            {tool.status === "coming-soon" && (
                                                <span class="text-[10px] uppercase tracking-wider text-[var(--color-mark)] opacity-80">
                                                    soon
                                                </span>
                                            )}
                                        </a>
                                    </li>
                                );
                            })}
                        </ul>
                    )}
                </div>
            ))
        }
    </nav>
</aside>
